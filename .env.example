# Heliox Monitor 配置

# HTTP 服务
HELIOX_MON_LISTEN=127.0.0.1:9100
HELIOX_MON_USER=admin
HELIOX_MON_PASS=your_password_here

# 数据目录
HELIOX_MON_DATA_DIR=/var/lib/heliox-mon

# Heliox 配置路径（用于读取端口）
HELIOX_ENV_PATH=/root/heliox/.env

# 服务器标识
SERVER_NAME=Heliox-LA

# 流量报警
MONTHLY_LIMIT_GB=5000
# 计费模式: bidirectional (双向), tx_only (仅出站), rx_only (仅入站), max_value (取最大值)
BILLING_MODE=bidirectional
RESET_DAY=1
ALERT_THRESHOLDS=80,90,95

# Telegram 通知（可选）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 每日流量报告（可选，需先配好上方 Telegram）
# 开启后每天在 DAILY_REPORT_HOUR 整点（按 HELIOX_MON_TZ 时区）推送昨日 + 本周期用量摘要
DAILY_REPORT_ENABLED=false
DAILY_REPORT_HOUR=9

# Cloudflare Turnstile (可选，设置后启用验证)
HELIOX_TURNSTILE_SECRET=

# Ping 延迟监控目标 (格式: TAG:IP)
PING_TARGETS=cloudflare:1.1.1.1,google:8.8.8.8
